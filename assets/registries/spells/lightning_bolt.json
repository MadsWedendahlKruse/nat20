{
    "id": "nat20_core::spell.lightning_bolt",
    "description": "A stroke of lightning forming a 100-foot-long, 5-foot-wide Line blasts out from you in a direction you choose. Each creature in the Line makes a Dexterity saving throw, taking 8d6 Lightning damage on a failed save or half as much damage on a successful one. Using a Higher-Level Spell Slot. The damage increases by 1d6 for each spell slot level above 3",
    "base_level": 3,
    "school": "evocation",
    "flags": [
        "verbal",
        "somatic"
    ],
    "kind": {
        "standard": {
            "condition": {
                "saving_throw": "spell_save_dc;dexterity"
            },
            "payload": {
                "damage": "(8 + spell_level - 3)d6;lightning",
                "damage_on_failure": "half",
                "delivery": "immediate"
            }
        }
    },
    "resource_cost": {
        "nat20_core::resource.action": 1
    },
    "targeting": {
        "kind": {
            "area": {
                "shape": {
                    "line": {
                        "length": "100 feet",
                        "width": "5 feet"
                    }
                },
                "fixed_on_actor": true
            }
        },
        "range": "100 feet",
        "line_of_sight": "ray",
        "allowed_targets": [
            {
                "life_states": [
                    "dead"
                ],
                "invert": true
            },
            {
                "tag": "not_self"
            }
        ]
    },
    "timeline": {
        "total_duration": 1.0,
        "perform_time": 0.5
    }
}