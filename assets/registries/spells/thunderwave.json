    "school": "evocation",
    "flags": [
        "verbal",
        "somatic"
    ],
    "kind": {
        "standard": {
            "phases": [
                {
                    "payload": {
                        "components": [
                            {
                                "damage": "(2  + spell_level - 1)d8;thunder",
                                "damage_on_failure": "half"
                            },
                            {
                                "displacement": {
                                    "push": {
                                        "distance": "10 feet"
                                    }
                                }
                            }
                        ],
                        "delivery": "immediate"
                    }
                }
            ]
        }
    },
    "resource_cost": {
        "nat20_core::resource.action": 1
    },
